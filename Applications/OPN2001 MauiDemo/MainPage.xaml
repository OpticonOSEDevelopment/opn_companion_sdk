<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Csp2NetMauiDemo.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
                Text="Opticon.Csp2Net Maui Demo"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />
            <Editor
                x:Name="LogEditor"
                HeightRequest="300"
                IsReadOnly="True"/> 
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
